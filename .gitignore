# Data files (sensitive - do not commit)
*.dta
*.rds
*.csv
*.sav
*.xlsx
*.xls
data/
output/
outputs/
intermediate/

# R workspace
.RData
.RDataTmp
.Rhistory
.Rproj.user/

# Rendered output
*.html
*.pdf
*.pptx
*.docx

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/

# Temp
*.tmp
nul

# ML pipeline outputs (regenerated by pipeline)
ml_pipeline/outputs_ML_results/*.csv
ml_pipeline/outputs_ML_results/*.pkl
ml_pipeline/outputs_ML_results/*.json
ml_pipeline/outputs_ML_results/*.npz
ml_pipeline/outputs_ML_results/*.png
ml_pipeline/outputs_ML_results/*.tiff
mlruns/

# Python
__pycache__/
*.pyc
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Aggregate result tables (shareable, no microdata) — override global *.csv ignore
!ml_pipeline/tables/
!ml_pipeline/tables/*.csv
